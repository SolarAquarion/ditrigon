<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>

  <object class="GtkBox" id="userlist_row">
    <property name="orientation">horizontal</property>
    <property name="spacing">8</property>
    <property name="margin-start">6</property>
    <property name="margin-end">6</property>
    <property name="margin-top">2</property>
    <property name="margin-bottom">2</property>
    <style>
      <class name="hc-user-row"/>
    </style>
    <child>
      <object class="GtkImage" id="userlist_presence_image">
        <property name="valign">center</property>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="userlist_content_box">
        <property name="orientation">vertical</property>
        <property name="spacing">0</property>
        <property name="hexpand">True</property>
        <property name="valign">center</property>
        <child>
          <object class="GtkLabel" id="userlist_name_label">
            <property name="label"></property>
            <property name="xalign">0.0</property>
            <property name="ellipsize">end</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="userlist_host_label">
            <property name="label"></property>
            <property name="xalign">0.0</property>
            <property name="ellipsize">end</property>
            <style>
              <class name="dim-label"/>
              <class name="caption"/>
              <class name="hc-user-host"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkLabel" id="userlist_badge_label">
        <property name="label"></property>
        <property name="valign">center</property>
        <property name="visible">False</property>
        <style>
          <class name="hc-user-role-badge"/>
        </style>
      </object>
    </child>
  </object>
</interface>
